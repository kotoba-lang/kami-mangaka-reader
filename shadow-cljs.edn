;; shadow-cljs build for the reagent + re-frame reader app (ADR-2606282101).
;; Pulls cljs/reagent/re-frame from deps.edn :cljs alias. Release output is a
;; single reader.js a static manga site includes (+ window.__manga/__locale data).
{:deps   {:aliases [:cljs]}
 :builds {:reader {:target     :browser
                   :output-dir "dist"
                   :asset-path "."
                   :modules    {:reader {:init-fn kami.mangaka.reader.app/init}}}}}
